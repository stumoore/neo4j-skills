      "generated_cypher": "CYPHER 25\nMATCH (u:User {userId: '1'})-[:RATED]->(watched:Movie)\nWITH u, collect(watched) AS watchedMovies\n\nMATCH (w:Movie)-[:IN_GENRE]->(g:Genre)\nWHERE w IN watchedMovies\nWITH u, watchedMovies, collect(DISTINCT g.name) AS userGenres\n\nMATCH (u)-[:RATED]->(common:Movie)<-[:RATED]-(peer:User)\nWHERE peer <> u\nWITH watchedMovies, userGenres, peer, count(common) AS sharedCount\n\nMATCH (peer)-[pr:RATED]->(candidate:Movie)\nWHERE NOT candidate IN watchedMovies\n  AND pr.rating >= 3.5\nWITH userGenres, candidate,\n     count(DISTINCT peer)                                AS peerCount,\n     sum(sharedCount * pr.rating) / sum(sharedCount)    AS weightedPeerRating\n\nMATCH (candidate)-[:IN_GENRE]->(cg:Genre)\nWITH userGenres, candidate, peerCount, weightedPeerRating,\n     collect(cg.name) AS candidateGenres\n\nWITH candidate, peerCount, weightedPeerRating,\n     toFloat(size([g IN candidateGenres WHERE g IN userGenres]))\n       / size(candidateGenres)                           AS genreOverlap\n\nWITH candidate, peerCount, weightedPeerRating,\n     0.7 * (weightedPeerRating / 5.0) + 0.3 * genreOverlap AS score\n\nRETURN candidate.title                            AS title,\n       candidate.released                         AS released,\n       candidate.imdbRating                       AS imdbRating,\n       round(weightedPeerRating * 100) / 100      AS weightedPeerRating,\n       peerCount,\n       round(score * 1000) / 1000                 AS score\nORDER BY score DESC\nLIMIT 10",
